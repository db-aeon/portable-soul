{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portablesoul.org/schemas/0.6.0-draft/bundle.manifest.schema.json",
  "title": "Portable Soul Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "bundle_id", "created_at", "source_agent_id", "artifact_index"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^0\\.6\\.0-draft$"
    },
    "conformance_level": {
      "type": "integer",
      "enum": [0, 1, 2],
      "default": 0
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "created_at": { "type": "string", "format": "date-time" },
    "source_agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "label": { "type": "string" },
    "composition_snapshot": { "type": "string" },
    "export_filter": {
      "type": "object",
      "additionalProperties": true
    },
    "artifact_index": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifactEntry" }
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "properties": {
          "path": { "type": "string" },
          "type": { "type": "string", "enum": ["c2pa", "self-issued", "x509"] }
        }
      }
    }
  },
  "$defs": {
    "artifactEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string" }
      }
    }
  }
}
