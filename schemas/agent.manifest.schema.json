{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portablesoul.org/schemas/0.6.0-draft/agent.manifest.schema.json",
  "title": "Portable Soul Agent Composition Manifest (Level 1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "agent_id", "metadata", "topology"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^0\\.6\\.0-draft$"
    },
    "conformance_level": { "type": "integer", "enum": [1] },
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "exported_at": { "type": "string", "format": "date-time" }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orchestration", "models", "memory_systems"],
      "properties": {
        "orchestration": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/orchestrationRole" }
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/modelBinding" }
        },
        "memory_systems": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/memorySystem" }
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolBinding" }
        },
        "connectors": {
          "type": "array",
          "items": { "$ref": "#/$defs/connectorBinding" }
        },
        "interfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/interfaceBinding" }
        }
      }
    }
  },
  "$defs": {
    "implementationRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "uri": {
          "type": "string",
          "pattern": "^urn:psoul:impl:[a-z0-9-]{1,64}$"
        },
        "modifications": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "orchestrationRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "implementation"],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "primary_reasoning_loop",
            "sandbox_execution",
            "gateway_router",
            "background_worker"
          ]
        },
        "implementation": { "$ref": "#/$defs/implementationRef" }
      }
    },
    "modelBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "provider", "endpoint", "tier"],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "primary_reasoner",
            "fallback_router",
            "embedding",
            "reranker",
            "voice",
            "extraction"
          ]
        },
        "provider": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 },
        "tier": {
          "type": "string",
          "enum": ["frontier-api", "edge-compute", "local-inference", "managed-service"]
        }
      }
    },
    "memorySystem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "implementation"],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "conversation_memory",
            "graph_memory",
            "file_index",
            "ephemeral_cache",
            "session_state"
          ]
        },
        "implementation": { "$ref": "#/$defs/implementationRef" },
        "exportable": {
          "type": "boolean",
          "description": "Whether this memory system supports PROV-compatible export."
        }
      }
    },
    "toolBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "protocol"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "protocol": {
          "type": "string",
          "enum": ["mcp", "openapi", "native", "grpc", "shell"]
        },
        "endpoint": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "connectorBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "provider"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "data_direction": {
          "type": "string",
          "enum": ["ingress", "egress", "bidirectional"]
        }
      }
    },
    "interfaceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "protocol"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["chat", "voice", "api", "scheduled_tasks", "webhook", "email"]
        },
        "protocol": { "type": "string", "minLength": 1 }
      }
    }
  }
}
