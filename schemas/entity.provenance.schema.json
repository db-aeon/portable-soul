{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portablesoul.org/schemas/0.5.0-draft/entity.provenance.schema.json",
  "title": "Portable Soul Entity Provenance Record",
  "description": "Provenance record for a single Entity. Ownership and license MUST NOT appear here.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity_id", "entity_type", "content_hash", "prov"],
  "properties": {
    "entity_id": {
      "type": "string",
      "pattern": "^urn:psoul:entity:[a-f0-9]{16}$"
    },
    "entity_type": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "fact",
            "preference",
            "heuristic",
            "skill",
            "workflow",
            "document",
            "memory_node",
            "playbook",
            "abstract_concept"
          ]
        },
        {
          "type": "string",
          "pattern": "^x-[a-z0-9-]+$"
        }
      ]
    },
    "content": {
      "description": "Entity payload. null when tombstoned.",
      "oneOf": [{ "type": "string" }, { "type": "object" }, { "type": "null" }]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "prov": { "$ref": "#/$defs/provenanceBlock" }
  },
  "not": {
    "anyOf": [
      { "required": ["license"] },
      { "required": ["ownership"] },
      { "required": ["data_class"] }
    ]
  },
  "$defs": {
    "actorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["person", "software", "org", "service"]
        },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "derivedFromEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "kind"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "conversation",
            "document",
            "connector",
            "import",
            "skill",
            "prior_version",
            "generalization"
          ]
        }
      }
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity", "agent"],
      "properties": {
        "activity": { "type": "string", "minLength": 1 },
        "agent": { "$ref": "#/$defs/actorRef" },
        "on_behalf_of": { "$ref": "#/$defs/actorRef" }
      }
    },
    "erasureBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["erased_at", "erased_by", "reason"],
      "properties": {
        "erased_at": { "type": "string", "format": "date-time" },
        "erased_by": { "$ref": "#/$defs/actorRef" },
        "reason": {
          "type": "string",
          "enum": ["subject_request", "retention_policy", "legal_hold_release", "x-other"]
        }
      }
    },
    "provenanceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_by", "derived_from", "generated_at"],
      "properties": {
        "generated_by": { "$ref": "#/$defs/generatedBy" },
        "derived_from": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/derivedFromEntry" }
        },
        "generated_at": { "type": "string", "format": "date-time" },
        "in_context": { "type": "string" },
        "erasure": { "$ref": "#/$defs/erasureBlock" }
      }
    }
  }
}
