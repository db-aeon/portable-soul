{
  "@context": {
    "@version": 1.1,
    "prov": "http://www.w3.org/ns/prov#",
    "psoul": "https://portablesoul.org/ns/0.5.0-draft#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "content": "psoul:content",
    "content_hash": "psoul:contentHash",
    "entityType": "psoul:entityType",
    "activityType": "psoul:activityType",
    "actorType": "psoul:actorType",
    "inContext": "psoul:inContext",
    "wasDerivedFrom": {
      "@id": "prov:wasDerivedFrom",
      "@type": "@id"
    },
    "wasGeneratedBy": {
      "@id": "prov:wasGeneratedBy",
      "@type": "@id"
    },
    "generatedAtTime": {
      "@id": "prov:generatedAtTime",
      "@type": "xsd:dateTime"
    },
    "actedOnBehalfOf": {
      "@id": "prov:actedOnBehalfOf",
      "@type": "@id"
    },
    "wasAssociatedWith": {
      "@id": "prov:wasAssociatedWith",
      "@type": "@id"
    }
  }
}
